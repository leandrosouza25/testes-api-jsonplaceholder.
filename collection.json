    {
      "name": "GET Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Resposta deve ser um array\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Deve retornar pelo menos um post\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.length).to.be.greaterThan(0);\r",
              "});\r",
              "pm.test(\"O primeiro post deve possuir userId\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response[0]).to.have.property('userId');\r",
              "});\r",
              "\r",
              "pm.test(\"O primeiro post deve possuir id\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response[0]).to.have.property('id');\r",
              "});\r",
              "\r",
              "pm.test(\"O primeiro post deve possuir title\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response[0]).to.have.property('title');\r",
              "});\r",
              "\r",
              "pm.test(\"O primeiro post deve possuir body\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response[0]).to.have.property('body');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
