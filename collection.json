              "    pm.expect(response).to.have.property('id');\r",
              "});\r",
              "\r",
              "pm.test(\"O título deve ser retornado corretamente\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.title).to.eql(\"Meu primeiro post automatizado\");\r",
              "});\r",
              "\r",
              "pm.test(\"O userId deve ser 1\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.userId).to.eql(1);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"post_id\", response.id);\r",
              "\r",
              "console.log(\"Post ID salvo:\", response.id);"
            ],
